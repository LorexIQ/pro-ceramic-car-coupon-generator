{
  "name": "pro-ceramic-car-coupon-generator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typescript && vite build && node -e \"require('fs').copyFileSync('dist/index.html','dist/404.html')\"",
    "preview": "vite preview",
    "typescript": "vue-tsc -b",
    "lint": "eslint . && stylelint \"src/**/*.{css,vue}\"",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.{css,vue}\" --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "idb-keyval": "^6.2.1",
    "imask": "^7.6.1",
    "naive-ui": "^2.41.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.9.4",
    "stylelint": "^17.14.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.62.1",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.2.0"
  }
}
